# Local backend
ENVIRONMENT=local
STORE_BACKEND=local
DATABASE_URL=postgresql+asyncpg://rankkit:rankkit@localhost:5432/rankkit
JWT_SECRET=dev-nextauth-secret-change-me
ALLOWED_ORIGINS=http://localhost:3000

# Local web
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
AUTH_REQUIRED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production backend
# ENVIRONMENT=production
# STORE_BACKEND=postgres
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/rankkit
# DATABASE_HOST=your-rds-endpoint.example
# DATABASE_PORT=5432
# DATABASE_NAME=rankkit
# DATABASE_USER=rankkit
# DATABASE_PASSWORD=replace-with-rds-secret-password
# JWT_SECRET=replace-with-the-same-32-character-or-longer-secret-used-by-nextauth
# ALLOWED_ORIGINS=https://your-web-app.example

# Production web
# NEXT_PUBLIC_API_URL=https://your-api.example
# NEXTAUTH_URL=https://your-web-app.example
# NEXTAUTH_SECRET=replace-with-the-same-32-character-or-longer-secret-used-by-backend
# AUTH_REQUIRED=true
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
