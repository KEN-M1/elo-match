{
  "name": "rankkit",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:db": "powershell -ExecutionPolicy Bypass -File scripts/dev-db.ps1",
    "dev:backend": "powershell -ExecutionPolicy Bypass -File scripts/dev-backend.ps1",
    "dev:web": "powershell -ExecutionPolicy Bypass -File scripts/dev-web.ps1",
    "start:backend": "powershell -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "build:web": "pnpm --filter @rankkit/web build",
    "start:web": "pnpm --filter @rankkit/web start",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File scripts/migrate-db.ps1",
    "db:smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-db.ps1",
    "db:sql": "powershell -ExecutionPolicy Bypass -File scripts/migration-sql.ps1",
    "db:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-db.ps1",
    "reset:local": "powershell -ExecutionPolicy Bypass -File scripts/reset-local-data.ps1",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "powershell -ExecutionPolicy Bypass -File scripts/test-all.ps1",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "^2.3.3"
  }
}
